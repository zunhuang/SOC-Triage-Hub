APP_NAME=IAM Triage Hub Middleware
APP_VERSION=0.1.0
NODE_ENV=development
LOG_LEVEL=info
FRONTEND_URL=http://localhost:3000

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=iam-triage-hub

JIRA_BASE_URL=https://jira.company.com
JIRA_USERNAME=api_user
JIRA_PASSWORD=replace_me
JIRA_JQL=project = "SOC" AND statusCategory != Done
JIRA_POLL_INTERVAL_MINUTES=5

KINDO_API_KEY=kindo-replace-me
KINDO_API_BASE_URL=https://api.kindo.ai/v1
KINDO_INFERENCE_URL=https://llm.kindo.ai/v1

LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=

AUTO_TRIAGE_ENABLED=false
ENABLE_INTERNAL_SCHEDULER=false
