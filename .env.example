# ===== Frontend =====
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ===== Backend Core =====
APP_NAME=Detect and Respond Middleware
APP_VERSION=0.1.0
NODE_ENV=development
LOG_LEVEL=info
FRONTEND_URL=http://localhost:3000

# ===== MongoDB Atlas =====
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=1
MONGODB_DB_NAME=SOC-triage-hub

# ===== Jira Data Center =====
JIRA_BASE_URL=https://jira.company.com
JIRA_USERNAME=api_user
JIRA_PASSWORD=replace_me
JIRA_JQL=project = "SOC" AND statusCategory != Done
JIRA_POLL_INTERVAL_MINUTES=5

# ===== Kindo =====
KINDO_API_KEY=replace_me
KINDO_API_BASE_URL=https://api.kindo.deloitte.com/v1
KINDO_INFERENCE_URL=https://llm.kindo.ai/v1

# ===== LLM Gateway =====
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=

# ===== Runtime =====
AUTO_TRIAGE_ENABLED=false
ENABLE_INTERNAL_SCHEDULER=false
