# ===== Frontend =====
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ===== Backend Core =====
APP_NAME=IAM Triage Hub Middleware
APP_VERSION=0.1.0
NODE_ENV=development
LOG_LEVEL=info
FRONTEND_URL=http://localhost:3000

# ===== MongoDB =====
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=iam-triage-hub

# ===== ServiceNow =====
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
SERVICENOW_USERNAME=api_user
SERVICENOW_PASSWORD=replace_me
SERVICENOW_ASSIGNMENT_GROUP=IAM Operations
SERVICENOW_POLL_INTERVAL_MINUTES=5

# ===== Kindo =====
KINDO_API_KEY=kindo-replace-me
KINDO_API_BASE_URL=https://api.kindo.ai/v1
KINDO_INFERENCE_URL=https://llm.kindo.ai/v1

# ===== LLM Gateway =====
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=

# ===== Runtime =====
AUTO_TRIAGE_ENABLED=false
ENABLE_INTERNAL_SCHEDULER=false
